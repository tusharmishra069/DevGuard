# DevGuard runtime configuration
# Copy this file to `.env` and customize values.

# Provider selection: groq | anthropic | gemini
DEVGUARD_PROVIDER=groq

# Model name for selected provider
DEVGUARD_MODEL=llama-3.3-70b-versatile

# Provider API keys (set the one you actually use)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
